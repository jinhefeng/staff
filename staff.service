[Unit]
Description=Staff Intelligent Agent Service
After=network.target

[Service]
Type=simple
User=jinhefeng
WorkingDirectory=/Users/jinhefeng/Dev/staff
Environment=NANOBOT_CONFIG_PATH=/Users/jinhefeng/Dev/staff/config.json
ExecStart=/Users/jinhefeng/Dev/staff/venv/bin/python -m nanobot gateway
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
