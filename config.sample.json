{
  "agents": {
    "defaults": {
      "name": "nanobot",
      "workspace": "./workspace",
      "provider": "nvidia",
      "maxTokens": 8192,
      "temperature": 0.6,
      "maxToolIterations": 40,
      "memoryWindow": 30,
      "sessionMaxMessages": 60,
      "sessionClearToSize": 40
    }
  },
  "providers": {
    "nvidia": {
      "model": "nvidia/minimaxai/minimax-m2.5",
      "apiKey": "请修改为您的 Nvidia API Key（与 model 对应）",
      "apiBase": "https://integrate.api.nvidia.com/v1"
    },
    "gemini": {
      "apiKey": "请修改为您的 Gemini API Key"
    }
  },
  "channels": {
    "dingtalk": {
      "enabled": false,
      "clientId": "在此填入您钉钉应用的 Client ID (AppKey)",
      "clientSecret": "在此填入您钉钉应用的 Client Secret (AppSecret)",
      "allowFrom": [],
      "masterIds": []
    }
  }
}